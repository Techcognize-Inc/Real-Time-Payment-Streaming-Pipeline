{
  "id": null,
  "uid": "payment-aggregates-v1",
  "title": "Payment Aggregates Dashboard",
  "description": "Real-time payment pipeline metrics from PostgreSQL",
  "tags": ["payments", "flink", "postgres"],
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "links": [],
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Transactions",
      "description": "Sum of all processed transactions",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(total_transactions) AS \"Total Transactions\" FROM payment_aggregates",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed Transactions",
      "description": "Sum of all failed transactions",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(failed_transactions) AS \"Failed Transactions\" FROM payment_aggregates",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Overall Success Rate",
      "description": "Average success rate across all banks and windows",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(CAST(AVG(success_rate) * 100 AS numeric), 2) AS \"Success Rate\" FROM payment_aggregates",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Transactions Over Time",
      "description": "Total, failed, and successful transactions per 1-minute window",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Successful" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT window_start::timestamp AS time, SUM(total_transactions) AS \"Total\", SUM(failed_transactions) AS \"Failed\", SUM(total_transactions) - SUM(failed_transactions) AS \"Successful\" FROM payment_aggregates GROUP BY window_start::timestamp ORDER BY time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Transactions by Payment Type",
      "description": "Distribution of transactions across payment types",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
      "options": {
        "displayLabels": ["percent", "name"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "pie",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(CASE WHEN payment_type = 'RTGS' THEN total_transactions ELSE 0 END) AS \"RTGS\", SUM(CASE WHEN payment_type = 'NEFT' THEN total_transactions ELSE 0 END) AS \"NEFT\", SUM(CASE WHEN payment_type = 'IMPS' THEN total_transactions ELSE 0 END) AS \"IMPS\" FROM payment_aggregates",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Transactions by Bank",
      "description": "Total transactions per bank code",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
      "options": {
        "barRadius": 0,
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "orientation": "auto",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT bank_code AS \"Bank\", SUM(total_transactions) AS \"Transactions\" FROM payment_aggregates GROUP BY bank_code ORDER BY \"Transactions\" DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Aggregates by Bank & Payment Type",
      "description": "Detailed breakdown per bank and payment type",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
      "options": {
        "footer": { "enablePagination": true, "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Total" }]
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Success Rate %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 90 },
                    { "color": "green", "value": 95 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "payments-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT bank_code AS \"Bank\", payment_type AS \"Payment Type\", SUM(total_transactions) AS \"Total\", SUM(failed_transactions) AS \"Failed\", ROUND(CAST(AVG(success_rate) * 100 AS numeric), 2) AS \"Success Rate %\", ROUND(CAST(SUM(total_amount) AS numeric), 2) AS \"Total Amount\" FROM payment_aggregates GROUP BY bank_code, payment_type ORDER BY \"Total\" DESC",
          "refId": "A"
        }
      ]
    }
  ]
}
